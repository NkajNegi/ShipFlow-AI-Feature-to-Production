# =============================================================================
# MetroFlow AI — environment variables
# Copy this file to apps/web/.env (and packages/db/.env for Prisma) and fill in.
# Legend:  [REQUIRED] app won't work without it · [OPTIONAL] feature-specific
# =============================================================================


# -----------------------------------------------------------------------------
# Database  [REQUIRED]
# -----------------------------------------------------------------------------
# PostgreSQL connection string. Cheapest good option: Neon (free, scale-to-zero).
#   Neon:     https://neon.tech  ->  create project  ->  "Connection string"
#   Supabase: https://supabase.com  ->  Project Settings -> Database -> URI
#   Vercel:   Vercel dashboard -> Storage -> Postgres -> .env tab
# Use the "pooled" connection string if your host offers one.
DATABASE_URL="postgresql://user:password@host:5432/metroflow?sslmode=require"


# -----------------------------------------------------------------------------
# Auth — BetterAuth  [REQUIRED]
# -----------------------------------------------------------------------------
# BETTER_AUTH_SECRET: any long random string. Generate one with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-openssl-rand-base64-32"
# Base URL of the app (no trailing slash). Local = http://localhost:3001
# In production set to your deployed URL, e.g. https://metroflow.vercel.app
BETTER_AUTH_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# GitHub social login (optional sign-in button). This is a GitHub *OAuth App*,
# which is SEPARATE from the GitHub *App* further down.
#   https://github.com/settings/developers -> OAuth Apps -> New OAuth App
#   Authorization callback URL: <APP_URL>/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""


# -----------------------------------------------------------------------------
# AI — providers (Vercel AI SDK)
# -----------------------------------------------------------------------------
# FREE / DEFAULT TIER [set at least one]: Gemini, OpenAI, and OpenRouter work
# together as an ensemble (each drafts; the first available synthesizes the
# final JSON). No Anthropic key is required for the free tier.
#   Gemini:     https://aistudio.google.com/apikey   (generous free tier)
GOOGLE_GENERATIVE_AI_API_KEY=""
# (GEMINI_API_KEY is accepted as an alias for the above.)
GEMINI_API_KEY=""
#   OpenAI:     https://platform.openai.com/api-keys  (needs paid credit)
OPENAI_API_KEY=""
#   OpenRouter: https://openrouter.ai/keys  (OpenAI-compatible gateway, free models)
OPENROUTER_API_KEY=""
# Optional: override the OpenRouter model (default openai/gpt-4o-mini).
OPENROUTER_MODEL=""
#
# BYOK (per user/workspace): a user can add their own Anthropic key in
# Settings -> AI Provider Key to run Claude Opus, billed to their account.
# This platform ANTHROPIC_API_KEY is an OPTIONAL last-resort fallback only.
#   https://console.anthropic.com -> Settings -> API Keys -> Create Key
ANTHROPIC_API_KEY=""


# -----------------------------------------------------------------------------
# Encryption  [REQUIRED]
# -----------------------------------------------------------------------------
# Encrypts workspace BYOK Anthropic keys at rest. 32 bytes, hex or base64:
#   openssl rand -hex 32
ENCRYPTION_KEY="replace-with-openssl-rand-hex-32"


# -----------------------------------------------------------------------------
# GitHub App — Octokit (repo sync, PR webhooks, AI review)  [REQUIRED for GitHub]
# -----------------------------------------------------------------------------
# Create at: https://github.com/settings/apps -> New GitHub App
#   Permissions: Pull requests (Read & write), Contents (Read), Metadata (Read)
#   Subscribe to event: Pull request
#   Webhook URL:        <APP_URL>/api/webhooks/github
#   Setup/callback URL: <APP_URL>/api/github/setup
# After creating: note the App ID, set a webhook secret, generate a private key.
GITHUB_APP_ID=""
# The app's URL slug (the name in github.com/apps/<slug>), used for the install link.
GITHUB_APP_SLUG="metroflow-ai"
# Paste the downloaded PEM. Single-line with \n escapes is supported, e.g.
#   "-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
GITHUB_APP_PRIVATE_KEY=""
# The webhook secret you set on the GitHub App page (any random string).
GITHUB_WEBHOOK_SECRET="replace-with-a-random-string"


# -----------------------------------------------------------------------------
# Slack intake  [OPTIONAL: only if you enable the /metroflow slash command]
# -----------------------------------------------------------------------------
# Create a Slack app -> Slash Commands -> new command (e.g. /metroflow).
#   Request URL: <APP_URL>/api/ingest/slack/<project ingest token>
# Then copy the app's "Signing Secret" (Basic Information) here so we can verify
# incoming commands. The project ingest token is shown on the Projects page.
SLACK_SIGNING_SECRET=""


# -----------------------------------------------------------------------------
# Inngest — async workflows  [REQUIRED in production; not needed for local dev]
# -----------------------------------------------------------------------------
# Local dev: run `npx inngest-cli@latest dev` (no keys needed).
# Production keys: https://app.inngest.com -> your app -> Manage -> Keys
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""


# -----------------------------------------------------------------------------
# Billing — Razorpay  [OPTIONAL: only if you enable paid plans]
# -----------------------------------------------------------------------------
# Dashboard: https://dashboard.razorpay.com
#   Keys:    Settings -> API Keys -> Generate Key (use Test Mode for demos)
#   Plan:    Subscriptions -> Plans -> create a "Pro" plan, copy its plan_id
#   Webhook: Settings -> Webhooks -> Add  (URL: <APP_URL>/api/webhooks/razorpay,
#            events: subscription.activated, subscription.charged; set a secret)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_PRO_PLAN_ID=""
RAZORPAY_WEBHOOK_SECRET=""


# -----------------------------------------------------------------------------
# Auth options & observability  [OPTIONAL]
# -----------------------------------------------------------------------------
# Require a verified email before login (needs a real mail sender wired up).
REQUIRE_EMAIL_VERIFICATION="false"
# Error tracking. Create a project at https://sentry.io -> copy the DSN, then
# wire @sentry/node in packages/api/src/lib/log.ts.
SENTRY_DSN=""
