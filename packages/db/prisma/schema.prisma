generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------
// BetterAuth Core Schema
// -----------------------------
model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @map("email_verified")
  image         String?
  // Per-user bring-your-own Anthropic (Claude) key, encrypted at rest. Used as
  // the default for the user's AI usage; a workspace key overrides it when set.
  anthropicApiKeyEnc String? @map("anthropic_api_key_enc") @db.Text
  // Per-user bring-your-own OpenRouter key, encrypted at rest.
  openRouterApiKeyEnc String? @map("openrouter_api_key_enc") @db.Text
  // Toggle: when false the saved key is kept but ignored (falls back to the
  // workspace/platform key) so the user can switch BYOK off without deleting it.
  aiKeyEnabled       Boolean @default(true) @map("ai_key_enabled")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions         Session[]
  accounts         Account[]
  workspaceMembers WorkspaceMember[]
  tasks            Task[]
  taskComments     TaskComment[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token") @db.Text
  refreshToken          String?   @map("refresh_token") @db.Text
  idToken               String?   @map("id_token") @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// -----------------------------
// MetroFlow SaaS Schema
// -----------------------------
model Workspace {
  id        String @id @default(cuid())
  name      String
  planTier  PlanTier @default(FREE) // FREE or PRO

  // Billing (Razorpay)
  razorpayCustomerId     String? @unique @map("razorpay_customer_id")
  razorpaySubscriptionId String? @unique @map("razorpay_subscription_id")
  aiReviewCredits        Int     @default(20) @map("ai_review_credits")

  // GitHub App installation
  githubInstallationId Int?    @unique @map("github_installation_id")
  githubAccountLogin   String? @map("github_account_login")

  // Bring-your-own AI key (Anthropic/Claude only), encrypted at rest
  anthropicApiKeyEnc String? @map("anthropic_api_key_enc")

  // Bring-your-own OpenRouter key, encrypted at rest
  openRouterApiKeyEnc String? @map("openrouter_api_key_enc")

  // Notifications (Slack / Discord incoming webhook)
  notifyWebhookUrl String? @map("notify_webhook_url")

  // Review SLA: hours allowed in human review/approval before a feature breaches.
  reviewSlaHours Int @default(24) @map("review_sla_hours")

  labels           Label[]
  notifyType  NotifyType? @map("notify_type") // SLACK or DISCORD

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      WorkspaceMember[]
  projects     Project[]
  subscription Subscription?
  invitations  Invitation[]

  @@map("workspace")
}

model Invitation {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  email       String
  role      WorkspaceRole @default(MEMBER) // ADMIN, LEAD, MEMBER
  token       String   @unique
  status      InvitationStatus @default(PENDING)
  invitedById String   @map("invited_by_id")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@index([token])
  @@map("invitation")
}

model Subscription {
  id          String   @id @default(cuid())
  workspaceId String   @unique @map("workspace_id")
  plan      PlanTier @default(FREE) // FREE or PRO
  status    SubscriptionStatus @default(ACTIVE) // ACTIVE, PAST_DUE, CANCELLED
  razorpayId  String?  @map("razorpay_id")
  currentPeriodEnd DateTime? @map("current_period_end")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("subscription")
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  workspaceId String    @map("workspace_id")
  role      WorkspaceRole @default(MEMBER) // ADMIN, LEAD, MEMBER
  createdAt   DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@map("workspace_member")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  workspaceId String   @map("workspace_id")
  // Secret token for external feature-request ingestion (email/ticket/API).
  ingestToken String   @unique @default(cuid()) @map("ingest_token")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  featureRequests FeatureRequest[]
  repositories    Repository[]
  tasks           Task[]

  @@map("project")
}

model FeatureRequest {
  id        String @id @default(cuid())
  title     String
  context   String @db.Text
  projectId String @map("project_id")
  // Where the request came from: UI, EMAIL, TICKET, API, SLACK
  source    FeatureSource @default(UI)
  // DISCOVERY, GENERATING_PRD, PLANNING, PLAN_APPROVED, IN_PROGRESS, IN_REVIEW,
  // FIX_NEEDED, APPROVED, SHIPPED, REJECTED, DUPLICATE_EDUCATION
  // (PLAN_APPROVED = plan reviewed & approved by a lead, ready for development)
  status    FeatureStatus @default(DISCOVERY)

  // Phase 1 AI clarification analysis (latest run)
  clarificationJson Json? @map("clarification_json")

  // Phase 5 AI release-readiness check (latest run)
  // readinessStatus: PENDING, COMPLETED, FAILED
  readinessStatus    JobStatus?   @map("readiness_status")
  // { verdict: READY|NEEDS_ATTENTION|NOT_READY, summary, blockers[], risks[], recommendations[] }
  readinessJson      Json?     @map("readiness_json")
  readinessCheckedAt DateTime? @map("readiness_checked_at")

  // Phase 5 human approval
  approvedById String?   @map("approved_by_id")
  approvedAt   DateTime? @map("approved_at")
  shippedAt    DateTime? @map("shipped_at")

  // Review SLA: when the feature first entered human review, and the deadline by
  // which it must be actioned. Set once on entering IN_REVIEW (not reset on
  // re-review loops, so breaches stay honest).
  reviewStartedAt DateTime? @map("review_started_at")
  reviewDueAt     DateTime? @map("review_due_at")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  prds         PRD[]
  pullRequests PullRequest[]

  @@index([projectId, status])
  @@index([status, reviewDueAt])
  @@map("feature_request")
}

model PRD {
  id               String   @id @default(cuid())
  featureRequestId String   @map("feature_request_id")
  contentJson      Json     // Stores goals, stories, edge cases generated by AI
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  featureRequest FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  tasks          Task[]

  @@map("prd")
}

model Task {
  id          String   @id @default(cuid())
  // Human-readable reference, e.g. SF-123, used in PR descriptions ("Closes SF-123")
  ref         Int      @default(autoincrement())
  title       String
  description String   @db.Text
  status    TaskStatus @default(TODO) // TODO, IN_PROGRESS, REVIEW, DONE
  priority  TaskPriority @default(MEDIUM) // LOW, MEDIUM, HIGH, URGENT
  position    Float    @default(0)
  dueDate     DateTime? @map("due_date")
  assigneeId  String?  @map("assignee_id")
  projectId   String?  @map("project_id")
  prdId       String?  @map("prd_id")
  // AI implementation walkthrough (steps + cursor), generated on demand.
  walkthroughJson Json? @map("walkthrough_json")
  walkthroughStep Int   @default(0) @map("walkthrough_step")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  prd      PRD?          @relation(fields: [prdId], references: [id], onDelete: Cascade)
  project  Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?         @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  comments TaskComment[]
  labels   TaskLabel[]

  @@index([projectId, status])
  @@map("task")
}

model TaskComment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  taskId    String   @map("task_id")
  authorId  String   @map("author_id")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("task_comment")
}

model Label {
  id          String   @id @default(cuid())
  name        String
  color       String   
  workspaceId String   @map("workspace_id")
  createdAt   DateTime @default(now())

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     TaskLabel[]

  @@map("label")
}

model TaskLabel {
  taskId  String @map("task_id")
  labelId String @map("label_id")

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@map("task_label")
}

model Repository {
  id          String   @id @default(cuid())
  name        String
  fullName    String?  @map("full_name") // owner/repo
  githubId    Int?     @unique
  url         String
  projectId   String   @map("project_id")
  // AI repository analysis (summary, stack, architecture, risks)
  analysisJson Json?     @map("analysis_json")
  analyzedAt   DateTime? @map("analyzed_at")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pullRequests  PullRequest[]
  commitReviews CommitReview[]

  @@map("repository")
}

// AI review of a single commit's diff (flaws + improvement suggestions).
// Independent of pull requests / PRDs — runs on demand for a chosen commit.
model CommitReview {
  id            String   @id @default(cuid())
  repositoryId  String   @map("repository_id")
  sha           String
  message       String   @db.Text
  authorName    String?  @map("author_name")
  htmlUrl       String?  @map("html_url")
  // PENDING, COMPLETED, FAILED
  status        JobStatus   @default(PENDING)
  summary       String?  @db.Text
  // Array of { type: FLAW|IMPROVEMENT, severity, category, title, detail, file?, suggestion? }
  findingsJson  Json?    @map("findings_json")
  error         String?  @db.Text
  // The user who requested it — lets us bill against their personal Anthropic key.
  requestedById String?  @map("requested_by_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, sha])
  @@map("commit_review")
}

model PullRequest {
  id               String  @id @default(cuid())
  number           Int
  title            String
  url              String
  headSha          String? @map("head_sha")
  state     PullRequestState  @default(OPEN) // OPEN, CLOSED, MERGED
  featureRequestId String  @map("feature_request_id")
  repositoryId     String? @map("repository_id")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  featureRequest FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  repository     Repository?    @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  reviews        Review[]

  @@unique([repositoryId, number])
  @@map("pull_request")
}

// Idempotency guard for inbound webhooks (GitHub / Razorpay re-send deliveries).
model WebhookEvent {
  id        String   @id @default(cuid())
  provider  String
  eventId   String   @map("event_id")
  createdAt DateTime @default(now())

  @@unique([provider, eventId])
  @@map("webhook_event")
}

// Audit trail for sensitive actions (approvals, role changes, removals).
model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  actorId     String   @map("actor_id")
  actorName   String?  @map("actor_name")
  action      String
  target      String?
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@map("audit_log")
}

// Tracks long-running async (Inngest) work so progress is visible in-app.
model WorkflowRun {
  id               String   @id @default(cuid())
  type             String   // PRD_GENERATION, AI_REVIEW, REPO_ANALYSIS
  status    WorkflowStatus   @default(RUNNING) // RUNNING, COMPLETED, FAILED
  label            String?
  featureRequestId String?  @map("feature_request_id")
  repositoryId     String?  @map("repository_id")
  stepsJson        Json?    @map("steps_json")
  error            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([featureRequestId])
  @@index([repositoryId])
  @@map("workflow_run")
}

// AI-generated implementation runs. Codegen drafts a code patch across multiple
// providers (ensemble), runs a Critic pass, and — if approved — opens a draft PR
// that flows into the existing AI review loop.
model CodegenRun {
  id               String  @id @default(cuid())
  featureRequestId String  @map("feature_request_id")
  repositoryId     String? @map("repository_id")
  // PENDING, DRAFTING, CRITIQUING, READY, PUSHED, FAILED
  status           CodegenStatus  @default(PENDING)
  // { files: [{path, action, newContent, rationale}], prTitle, prBody, testNotes[] }
  patchJson        Json?   @map("patch_json")
  // Critic verdict: { approved: bool, score: int, issues: [{severity, title, detail}] }
  critiqueJson     Json?   @map("critique_json")
  // How the patch was produced, surfaced in the UI (e.g. "ensemble:3 + critic")
  modelStrategy    String? @map("model_strategy")
  branch           String?
  prNumber         Int?    @map("pr_number")
  prUrl            String? @map("pr_url")
  error            String? @db.Text
  requestedById    String? @map("requested_by_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([featureRequestId])
  @@map("codegen_run")
}

// Fixed-window rate limiting for abuse-prone (AI) endpoints.
model RateLimit {
  id        String   @id @default(cuid())
  bucketKey String   @unique @map("bucket_key")
  count     Int      @default(0)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@map("rate_limit")
}

model Review {
  id            String   @id @default(cuid())
  pullRequestId String   @map("pull_request_id")
  // PENDING, APPROVED, CHANGES_REQUESTED
  status        ReviewStatus   @default(PENDING)
  summary       String?  @db.Text
  // Array of { severity: BLOCKING|NON_BLOCKING, category, title, detail, file? }
  issuesJson    Json?    @map("issues_json")
  blockingCount Int      @default(0) @map("blocking_count")
  iteration     Int      @default(1)
  dimensionsJson Json?   @map("dimensions_json")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pullRequest PullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)

  @@index([pullRequestId, createdAt])
  @@map("review")
}

enum PlanTier {
  FREE
  PRO
}

enum NotifyType {
  SLACK
  DISCORD
}

enum WorkspaceRole {
  ADMIN
  LEAD
  MEMBER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum FeatureSource {
  UI
  EMAIL
  TICKET
  API
  SLACK
}

enum FeatureStatus {
  DISCOVERY
  GENERATING_PRD
  PLANNING
  PLAN_APPROVED
  IN_PROGRESS
  IN_REVIEW
  FIX_NEEDED
  APPROVED
  SHIPPED
  REJECTED
  DUPLICATE_EDUCATION
}

enum JobStatus {
  PENDING
  COMPLETED
  FAILED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PullRequestState {
  OPEN
  CLOSED
  MERGED
}

enum WorkflowStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum CodegenStatus {
  PENDING
  DRAFTING
  CRITIQUING
  READY
  PUSHED
  FAILED
}

enum ReviewStatus {
  PENDING
  APPROVED
  CHANGES_REQUESTED
}
